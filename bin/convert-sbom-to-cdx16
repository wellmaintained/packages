#!/usr/bin/env bash
set -euo pipefail

# Convert a CycloneDX SBOM (any version) to CycloneDX 1.6 in-place.
# Usage: bin/convert-sbom-to-cdx16 <sbom-file>

SBOM="${1:?Usage: convert-sbom-to-cdx16 <sbom-file>}"

if [ ! -f "$SBOM" ]; then
  echo "ERROR: file not found: $SBOM" >&2
  exit 1
fi

# Use cyclonedx from PATH, or fall back to nix
if command -v cyclonedx &>/dev/null; then
  CYCLONEDX=cyclonedx
else
  nix build nixpkgs#cyclonedx-cli -o /tmp/cyclonedx-cli --no-link 2>/dev/null || true
  CYCLONEDX="$(nix build nixpkgs#cyclonedx-cli --print-out-paths)/bin/cyclonedx"
fi

"$CYCLONEDX" convert \
  --input-file "$SBOM" \
  --output-file "${SBOM}.tmp" \
  --input-format json \
  --output-format json \
  --output-version v1_6

mv "${SBOM}.tmp" "$SBOM"
