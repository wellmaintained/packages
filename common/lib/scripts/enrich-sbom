#!/usr/bin/env bash
# enrich-sbom — Enrich a CycloneDX SBOM via sbomify-action.
#
# Shared script used by both local `just build-image` and CI (build.yml).
# Requires sbomify-action CLI on PATH (provided by the ci devShell or nix build).
#
# Usage:
#   enrich-sbom --sbom-file PATH --sbomify-component-id ID --name NAME --version VER [--output PATH]
#
# Environment:
#   SBOMIFY_TOKEN  — API token. If unset, enrichment is skipped gracefully.

set -euo pipefail

usage() {
  cat >&2 <<EOF
Usage: $0 --sbom-file PATH --sbomify-component-id ID --name NAME --version VER [--output PATH]

Options:
  --sbom-file PATH      Input SBOM file (CycloneDX JSON)
  --sbomify-component-id ID     sbomify component ID
  --name NAME           Component display name
  --version VER         Component version
  --output PATH         Output file (default: <name>.enriched.cdx.json)

Environment:
  SBOMIFY_TOKEN         API token (enrichment skipped if unset)
EOF
  exit 1
}

sbom_file="" component_id="" name="" version="" output=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sbom-file)     sbom_file="$2"; shift 2 ;;
    --sbomify-component-id)  component_id="$2"; shift 2 ;;
    --name)          name="$2"; shift 2 ;;
    --version)       version="$2"; shift 2 ;;
    --output)        output="$2"; shift 2 ;;
    -h|--help)       usage ;;
    *)               echo "Unknown option: $1" >&2; usage ;;
  esac
done

[[ -z "$sbom_file" || -z "$component_id" || -z "$name" || -z "$version" ]] && {
  echo "ERROR: --sbom-file, --sbomify-component-id, --name, and --version are required" >&2
  usage
}

output="${output:-${name}.enriched.cdx.json}"

if [[ -z "${SBOMIFY_TOKEN:-}" ]]; then
  echo "==> SBOMIFY_TOKEN not set — skipping enrichment, copying raw SBOM" >&2
  cp "$sbom_file" "$output"
  echo "$output"
  exit 0
fi

echo "==> Enriching SBOM for ${name} v${version}" >&2

# sbomify-action reads config from env vars and CLI flags.
# On failure, fall back to the raw SBOM so downstream steps always have a file.
if TOKEN="$SBOMIFY_TOKEN" \
   COMPONENT_ID="$component_id" \
   COMPONENT_NAME="$name" \
   COMPONENT_VERSION="$version" \
   SBOM_FILE="$sbom_file" \
   SBOM_FORMAT=cyclonedx \
   AUGMENT=true \
   ENRICH=true \
   UPLOAD=false \
   OUTPUT_FILE="$output" \
     sbomify-action 2>&1 | while IFS= read -r line; do echo "  [sbomify] $line" >&2; done
then
  # Verify output was actually written (pipe can mask exit codes)
  if [[ ! -f "$output" ]]; then
    echo "WARNING: enrichment produced no output, falling back to raw SBOM" >&2
    cp "$sbom_file" "$output"
  fi
else
  echo "ERROR: sbomify-action failed — falling back to raw SBOM" >&2
  cp "$sbom_file" "$output"
fi

echo "$output"
