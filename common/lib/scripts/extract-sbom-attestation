#!/usr/bin/env bash
# common/lib/scripts/extract-sbom-attestation — Extract CycloneDX SBOM from OCI attestation.
#
# Usage:
#   common/lib/scripts/extract-sbom-attestation \
#     --image <name> \
#     --tag <component-tag> \
#     --output <path>
#
# Requires: crane, cosign, jq, base64
#
# Fast path: uses crane to fetch attestation layers directly via .att tags.
# Slow path: falls back to cosign for OCI referrers-based storage (cosign v2).

set -euo pipefail

usage() {
  echo "Usage: $0 --image NAME --tag COMPONENT_TAG --output PATH [--registry REGISTRY]"
  exit 1
}

IMAGE=""
TAG=""
OUTPUT=""
REGISTRY="${REGISTRY:-ghcr.io/wellmaintained/packages}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --image) IMAGE="$2"; shift 2 ;;
    --tag) TAG="$2"; shift 2 ;;
    --output) OUTPUT="$2"; shift 2 ;;
    --registry) REGISTRY="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$IMAGE" || -z "$TAG" || -z "$OUTPUT" ]] && usage

REPO="${REGISTRY}/${IMAGE}"

echo "==> Resolving digest for ${REPO}:${TAG}" >&2

DIGEST=$(crane digest "${REPO}:${TAG}" 2>&1) || {
  echo "ERROR: crane digest failed with: ${DIGEST}" >&2
  echo "Component tag '${TAG}' not found for ${REPO}." >&2
  exit 1
}

IMAGE_REF="${REPO}@${DIGEST}"
echo "==> Extracting SBOM attestation from ${IMAGE_REF}" >&2

OUTPUT_DIR=$(dirname "$OUTPUT")
mkdir -p "$OUTPUT_DIR"

# Fast path: cosign's legacy tag-based storage uses sha256-<hash>.att tags.
# Each layer carries a DSSE envelope with a predicateType annotation.
ATT_TAG="sha256-${DIGEST#sha256:}.att"
ATT_REF="${REPO}:${ATT_TAG}"

if ATT_MANIFEST=$(crane manifest "${ATT_REF}" 2>/dev/null); then
  echo "==> Found attestation via .att tag" >&2

  LAYER_DIGEST=$(echo "$ATT_MANIFEST" \
    | jq -r '.layers[]
             | select(.annotations["predicateType"] == "https://cyclonedx.org/bom")
             | .digest' \
    | head -1)

  if [[ -z "$LAYER_DIGEST" ]]; then
    echo "ERROR: No CycloneDX attestation found in ${ATT_REF}" >&2
    exit 1
  fi

  crane blob "${REPO}@${LAYER_DIGEST}" \
    | jq -r 'if has("dsseEnvelope") then .dsseEnvelope.payload else .payload end' \
    | base64 -d | jq '.predicate' \
    > "$OUTPUT"
else
  # Slow path: cosign v2 stores attestations via OCI referrers API.
  # Fall back to cosign which handles referrer discovery.
  echo "==> .att tag not found, falling back to cosign" >&2

  COSIGN_OUTPUT=$(cosign download attestation \
    --predicate-type https://cyclonedx.org/bom \
    "${IMAGE_REF}") || {
    echo "ERROR: cosign download attestation failed for ${IMAGE_REF}" >&2
    exit 1
  }

  if [[ -z "$COSIGN_OUTPUT" ]]; then
    echo "ERROR: No CycloneDX attestation found for ${IMAGE_REF}" >&2
    exit 1
  fi

  echo "$COSIGN_OUTPUT" \
    | jq -s 'first | if has("dsseEnvelope") then .dsseEnvelope.payload else .payload end' -r \
    | base64 -d | jq '.predicate' \
    > "$OUTPUT"
fi

echo "==> SBOM extracted to ${OUTPUT}" >&2
