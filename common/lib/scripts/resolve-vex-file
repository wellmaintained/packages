#!/usr/bin/env bash
# common/lib/scripts/resolve-vex-file — Find the VEX file for an image.
#
# Usage:
#   common/lib/scripts/resolve-vex-file --image <name>
#
# Searches common/images/ then apps/sbomify/images/ for {name}.vex.yaml.
# Prints the path to stdout if found, exits 0.
# Prints nothing and exits 0 if not found (caller decides if that's an error).

set -euo pipefail

usage() {
  echo "Usage: $0 --image NAME"
  exit 1
}

IMAGE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --image) IMAGE="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$IMAGE" ]] && usage

for candidate in "common/images/${IMAGE}.vex.yaml" "apps/sbomify/images/${IMAGE}.vex.yaml"; do
  if [[ -f "$candidate" ]]; then
    echo "$candidate"
    exit 0
  fi
done
