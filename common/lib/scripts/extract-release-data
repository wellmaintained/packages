#!/usr/bin/env bash
# common/lib/scripts/extract-release-data — Populate Hugo site data from built SBOMs.
#
# Usage:
#   common/lib/scripts/extract-release-data \
#     --sbom-dir DIR \
#     --scan-dir DIR \
#     --image-matrix FILE \
#     --output-dir DIR \
#     --tag TAG \
#     --version VERSION \
#     --date DATE
#
# Reads enriched CycloneDX SBOMs from --sbom-dir, Grype scan results from
# --scan-dir, extracts per-image metadata, and writes into --output-dir:
#   data/release.json          — release metadata
#   data/vulnerabilities.json  — aggregated Grype findings
#   data/licenses.json         — per-image license/component data
#   static/artifacts/sboms/    — one SBOM per image
#
# Requires: jq, yq

set -euo pipefail

usage() {
  echo "Usage: $0 --sbom-dir DIR --scan-dir DIR --image-matrix FILE --output-dir DIR --tag TAG --version VERSION --date DATE"
  exit 1
}

SBOM_DIR=""
SCAN_DIR=""
IMAGE_MATRIX=""
OUTPUT_DIR=""
TAG=""
VERSION=""
DATE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sbom-dir) SBOM_DIR="$2"; shift 2 ;;
    --scan-dir) SCAN_DIR="$2"; shift 2 ;;
    --image-matrix) IMAGE_MATRIX="$2"; shift 2 ;;
    --output-dir) OUTPUT_DIR="$2"; shift 2 ;;
    --tag) TAG="$2"; shift 2 ;;
    --version) VERSION="$2"; shift 2 ;;
    --date) DATE="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$SBOM_DIR" || -z "$SCAN_DIR" || -z "$IMAGE_MATRIX" || -z "$OUTPUT_DIR" || -z "$TAG" || -z "$VERSION" || -z "$DATE" ]] && usage

# Read image names from the matrix
IMAGES=$(jq -r '.[].name' "$IMAGE_MATRIX")

# Prepare output directories
ARTIFACTS_DIR="${OUTPUT_DIR}/static/artifacts/sboms"
DATA_DIR="${OUTPUT_DIR}/data"
mkdir -p "$ARTIFACTS_DIR" "$DATA_DIR"

# Build the images JSON array
IMAGES_JSON="[]"

for IMAGE in $IMAGES; do
  SBOM_FILE="${SBOM_DIR}/${IMAGE}.enriched.cdx.json"

  if [[ ! -f "$SBOM_FILE" ]]; then
    echo "ERROR: SBOM not found for ${IMAGE}: ${SBOM_FILE}" >&2
    echo "Run 'just build-image --all' first." >&2
    exit 1
  fi

  # Extract upstream version from SBOM metadata
  UPSTREAM_VERSION=$(jq -r '.metadata.component.version // empty' "$SBOM_FILE")
  if [[ -z "$UPSTREAM_VERSION" ]]; then
    echo "WARNING: No version found in SBOM metadata for ${IMAGE}, using 'unknown'" >&2
    UPSTREAM_VERSION="unknown"
  fi

  echo "==> ${IMAGE}: upstream_version=${UPSTREAM_VERSION}" >&2

  # Copy SBOM to Hugo static directory
  cp "$SBOM_FILE" "${ARTIFACTS_DIR}/${IMAGE}.cdx.json"

  # Append to images array
  IMAGES_JSON=$(echo "$IMAGES_JSON" | jq \
    --arg name "$IMAGE" \
    --arg upstream_version "$UPSTREAM_VERSION" \
    --arg tag "local-build" \
    --arg digest "sha256:local" \
    '. + [{ name: $name, upstream_version: $upstream_version, tag: $tag, digest: $digest }]')
done

# Write release.json
jq -n \
  --arg tag "$TAG" \
  --arg version "$VERSION" \
  --arg date "$DATE" \
  --argjson images "$IMAGES_JSON" \
  '{ tag: $tag, version: $version, date: $date, images: $images }' \
  > "${DATA_DIR}/release.json"

echo "==> Wrote ${DATA_DIR}/release.json (${TAG}, ${VERSION}, $(echo "$IMAGES" | wc -w) images)" >&2
echo "==> SBOMs copied to ${ARTIFACTS_DIR}/" >&2

# --- Vulnerability data ---
# Use temp files to avoid "Argument list too long" with many findings
VULN_TMPDIR=$(mktemp -d)

echo '[]' > "${VULN_TMPDIR}/findings.json"
echo '[]' > "${VULN_TMPDIR}/vex.json"
echo '[]' > "${VULN_TMPDIR}/scanned.json"
echo '[]' > "${VULN_TMPDIR}/missing.json"

for IMAGE in $IMAGES; do
  SCAN_FILE="${SCAN_DIR}/${IMAGE}.scan.json"
  if [[ ! -f "$SCAN_FILE" ]]; then
    echo "==> ${IMAGE}: no scan results (run 'just scan-sbom ${IMAGE}' to generate)" >&2
    jq --arg i "$IMAGE" '. + [$i]' "${VULN_TMPDIR}/missing.json" > "${VULN_TMPDIR}/missing.tmp" \
      && mv "${VULN_TMPDIR}/missing.tmp" "${VULN_TMPDIR}/missing.json"
    continue
  fi

  jq --arg i "$IMAGE" '. + [$i]' "${VULN_TMPDIR}/scanned.json" > "${VULN_TMPDIR}/scanned.tmp" \
    && mv "${VULN_TMPDIR}/scanned.tmp" "${VULN_TMPDIR}/scanned.json"

  # Extract findings from Grype output
  jq --arg image "$IMAGE" '
    [.matches[] | {
      cve: .vulnerability.id,
      severity: .vulnerability.severity,
      image: $image,
      package: .artifact.name,
      installed: .artifact.version,
      fixed_in: (if .vulnerability.fix.versions | length > 0 then .vulnerability.fix.versions[0] else null end),
      vex_status: null,
      vex_justification: null,
      vex_impact: null
    }]' "$SCAN_FILE" > "${VULN_TMPDIR}/${IMAGE}-findings.json"

  # Resolve VEX file
  VEX_FILE=$(common/lib/scripts/resolve-vex-file --image "$IMAGE")

  if [[ -n "$VEX_FILE" ]]; then
    # Parse VEX statements for this image
    yq -o json '.statements // []' "$VEX_FILE" | jq --arg image "$IMAGE" '
      [.[] | {
        cve: .vulnerability.name,
        image: $image,
        status: .status,
        justification: (.justification // null),
        impact: (.impact_statement // .action_statement // null)
      }]' > "${VULN_TMPDIR}/${IMAGE}-vex.json"

    # Annotate existing findings with VEX status
    for CVE_ID in $(jq -r '.[] | select(.status == "affected") | .cve' "${VULN_TMPDIR}/${IMAGE}-vex.json"); do
      jq --arg cve "$CVE_ID" \
        --slurpfile vex "${VULN_TMPDIR}/${IMAGE}-vex.json" '
        ($vex[0][] | select(.cve == $cve)) as $entry |
        [.[] | if .cve == $cve then .vex_status = $entry.status | .vex_impact = $entry.impact else . end]' \
        "${VULN_TMPDIR}/${IMAGE}-findings.json" > "${VULN_TMPDIR}/${IMAGE}-findings.tmp" \
        && mv "${VULN_TMPDIR}/${IMAGE}-findings.tmp" "${VULN_TMPDIR}/${IMAGE}-findings.json"
    done

    # Merge VEX statements
    jq -s '.[0] + .[1]' "${VULN_TMPDIR}/vex.json" "${VULN_TMPDIR}/${IMAGE}-vex.json" > "${VULN_TMPDIR}/vex.tmp" \
      && mv "${VULN_TMPDIR}/vex.tmp" "${VULN_TMPDIR}/vex.json"

    FINDING_COUNT=$(jq 'length' "${VULN_TMPDIR}/${IMAGE}-findings.json")
    VEX_COUNT=$(jq 'length' "${VULN_TMPDIR}/${IMAGE}-vex.json")
    echo "==> ${IMAGE}: ${FINDING_COUNT} vulnerabilities, ${VEX_COUNT} VEX statements (from ${VEX_FILE})" >&2
  else
    echo "==> ${IMAGE}: $(jq 'length' "${VULN_TMPDIR}/${IMAGE}-findings.json") vulnerabilities, no VEX file" >&2
  fi

  # Merge findings
  jq -s '.[0] + .[1]' "${VULN_TMPDIR}/findings.json" "${VULN_TMPDIR}/${IMAGE}-findings.json" > "${VULN_TMPDIR}/findings.tmp" \
    && mv "${VULN_TMPDIR}/findings.tmp" "${VULN_TMPDIR}/findings.json"
done

# Build final vulnerabilities.json
jq -s '{
  summary: (.[0] | { Critical: 0, High: 0, Medium: 0, Low: 0, Negligible: 0 } +
    (group_by(.severity) | map({ (.[0].severity): length }) | add // {})),
  findings: .[0],
  vex_statements: .[1],
  scanned_images: .[2],
  missing_images: .[3]
}' "${VULN_TMPDIR}/findings.json" "${VULN_TMPDIR}/vex.json" "${VULN_TMPDIR}/scanned.json" "${VULN_TMPDIR}/missing.json" \
  > "${DATA_DIR}/vulnerabilities.json"

FINDING_TOTAL=$(jq '.findings | length' "${DATA_DIR}/vulnerabilities.json")
VEX_SUPPRESSED=$(jq '[.vex_statements[] | select(.status == "not_affected")] | length' "${DATA_DIR}/vulnerabilities.json")
SCANNED_TOTAL=$(jq '.scanned_images | length' "${DATA_DIR}/vulnerabilities.json")
echo "==> Wrote ${DATA_DIR}/vulnerabilities.json (${FINDING_TOTAL} findings, ${VEX_SUPPRESSED} suppressed by VEX, ${SCANNED_TOTAL} images scanned)" >&2

rm -rf "${VULN_TMPDIR}"

# --- License data ---
# Use temp files to avoid "Argument list too long" with large SBOMs
LICENSES_TMPDIR=$(mktemp -d)
trap "rm -rf '$LICENSES_TMPDIR'" EXIT

echo '{}' > "${LICENSES_TMPDIR}/licenses.json"

for IMAGE in $IMAGES; do
  SBOM_FILE="${SBOM_DIR}/${IMAGE}.enriched.cdx.json"

  jq '
    [.components[]
     | select(.licenses != null and (.licenses | length > 0))
     | {
         component: .name,
         version: .version,
         license: (.licenses[0].license.id // .licenses[0].license.name // "Unknown"),
         description: (.description // ""),
         website: ([.externalReferences[]? | select(.type == "website") | .url][0] // null)
       }
    ] | sort_by(.component)' "$SBOM_FILE" > "${LICENSES_TMPDIR}/${IMAGE}.json"

  jq --arg image "$IMAGE" --slurpfile components "${LICENSES_TMPDIR}/${IMAGE}.json" \
    '. + {($image): $components[0]}' \
    "${LICENSES_TMPDIR}/licenses.json" > "${LICENSES_TMPDIR}/licenses.tmp" \
    && mv "${LICENSES_TMPDIR}/licenses.tmp" "${LICENSES_TMPDIR}/licenses.json"
done

# Build license summary (aggregate across all images)
jq '{ summary: ([.[][] | .license] | group_by(.) | map({license: .[0], count: length}) | sort_by(-.count)), images: . }' \
  "${LICENSES_TMPDIR}/licenses.json" \
  > "${DATA_DIR}/licenses.json"

echo "==> Wrote ${DATA_DIR}/licenses.json ($(jq '.summary | length' "${DATA_DIR}/licenses.json") distinct licenses)" >&2
