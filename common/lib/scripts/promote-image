#!/usr/bin/env bash
# bin/promote-image — re-tag a PR image by digest with release tags.
#
# Usage:
#   bin/promote-image \
#     --image <name> \
#     --pr <number> \
#     --sha <sha7> \
#     --version <upstream-version> \
#     [--sbomify-component-id <id>] \
#     [--sbomify-token <token>] \
#     [--sbom-file <path>]
#
# Requires: crane (from nixpkgs), gh (optional, for sbomify upload)

set -euo pipefail

usage() {
  echo "Usage: $0 --image NAME --pr NUMBER --sha SHA7 --version VERSION [--sbomify-component-id ID] [--sbomify-token TOKEN] [--sbom-file PATH]"
  exit 1
}

IMAGE=""
PR=""
SHA=""
VERSION=""
SBOMIFY_COMPONENT_ID=""
SBOMIFY_TOKEN=""
SBOM_FILE=""
REGISTRY="${REGISTRY:-ghcr.io/wellmaintained/packages}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --image) IMAGE="$2"; shift 2 ;;
    --pr) PR="$2"; shift 2 ;;
    --sha) SHA="$2"; shift 2 ;;
    --version) VERSION="$2"; shift 2 ;;
    --sbomify-component-id) SBOMIFY_COMPONENT_ID="$2"; shift 2 ;;
    --sbomify-token) SBOMIFY_TOKEN="$2"; shift 2 ;;
    --sbom-file) SBOM_FILE="$2"; shift 2 ;;
    --registry) REGISTRY="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$IMAGE" || -z "$PR" || -z "$SHA" || -z "$VERSION" ]] && usage

REPO="${REGISTRY}/${IMAGE}"
PR_TAG="pr-${PR}-${SHA}"
CALVER=$(date -u '+%Y%m%d%H%M')

echo "==> Promoting ${REPO}:${PR_TAG}"

# Resolve the digest of the PR-tagged image
DIGEST=$(crane digest "${REPO}:${PR_TAG}" 2>&1) || {
  echo "ERROR: crane digest failed with: ${DIGEST}"
  echo "PR tag '${PR_TAG}' not found for ${REPO}."
  exit 1
}

echo "    Digest: ${DIGEST}"

# Re-tag with release tags (by digest — no layer copy, just tag pointer)
for TAG in "latest" "${VERSION}" "${VERSION}-${CALVER}"; do
  echo "    Tagging: ${REPO}:${TAG}"
  crane tag "${REPO}@${DIGEST}" "${TAG}"
done

echo "==> Promotion complete for ${IMAGE}"

# Upload SBOM to sbomify.com if credentials and file provided
if [[ -n "$SBOMIFY_COMPONENT_ID" && -n "$SBOMIFY_TOKEN" && -n "$SBOM_FILE" ]]; then
  if [[ "$SBOMIFY_COMPONENT_ID" == PLACEHOLDER_* ]]; then
    echo "    Skipping sbomify upload (placeholder component ID)"
  elif [[ ! -f "$SBOM_FILE" ]]; then
    echo "    WARNING: SBOM file not found: ${SBOM_FILE}"
  else
    echo "    Uploading SBOM to sbomify.com (component: ${SBOMIFY_COMPONENT_ID})"
    # sbomify-action handles upload in CI; for local testing this is a placeholder
    echo "    SBOM upload would happen here (handled by sbomify-action in CI)"
  fi
fi
