#!/usr/bin/env bash
# common/lib/scripts/scan-sbom — Scan a CycloneDX SBOM for vulnerabilities using grype.
#
# Usage:
#   common/lib/scripts/scan-sbom \
#     --sbom <path> \
#     --output <output-path> \
#     [--format sarif|json] \
#     [--vex <vex-yaml-path>]
#
# Exits 0 with no output file if the SBOM does not exist.
# Exits non-zero if grype fails.
# Requires: grype, yq (for --vex YAML→JSON conversion)

set -euo pipefail

usage() {
  echo "Usage: $0 --sbom PATH --output PATH [--format sarif|json] [--vex PATH]"
  exit 1
}

SBOM=""
OUTPUT=""
FORMAT="sarif"
VEX=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sbom)   SBOM="$2";   shift 2 ;;
    --output) OUTPUT="$2"; shift 2 ;;
    --format) FORMAT="$2"; shift 2 ;;
    --vex)    VEX="$2";    shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$SBOM" || -z "$OUTPUT" ]] && usage

if [[ ! -f "$SBOM" ]]; then
  echo "==> No SBOM found at ${SBOM}, skipping vulnerability scan" >&2
  exit 0
fi

case "$FORMAT" in
  sarif|json) ;;
  *) echo "ERROR: unknown format '${FORMAT}' (expected sarif or json)" >&2; exit 1 ;;
esac

VEX_ARGS=()
VEX_TMPFILE=""
if [[ -n "$VEX" ]]; then
  if [[ ! -f "$VEX" ]]; then
    echo "==> VEX file not found at ${VEX}, scanning without VEX suppression" >&2
  else
    VEX_TMPFILE=$(mktemp --suffix=.vex.json)
    trap 'rm -f "$VEX_TMPFILE"' EXIT
    yq -o json "$VEX" > "$VEX_TMPFILE"
    VEX_ARGS=(--vex "$VEX_TMPFILE")
    echo "==> Using VEX suppression from ${VEX}" >&2
  fi
fi

echo "==> Scanning ${SBOM} for vulnerabilities" >&2
grype "sbom:${SBOM}" -o "$FORMAT" --file "$OUTPUT" "${VEX_ARGS[@]}"

# grype's SARIF presenter doesn't handle SBOM inputs well:
#  - artifactLocation.uri is "/" (SBOMFileMetadata not handled in presenter)
#  - message.text has trailing "at: " (empty packagePath for SBOM-sourced packages)
# Post-process the SARIF to fix these issues.
# See: https://github.com/anchore/grype/blob/main/grype/presenter/sarif/presenter.go
if [[ "$FORMAT" == "sarif" && -f "$OUTPUT" ]]; then
  SBOM_BASENAME="$(basename "$SBOM")"
  if jq --arg sbom_uri "$SBOM_BASENAME" '
    (.runs // [])[] |= (
      # Fix artifactLocation.uri: replace empty or "/" with SBOM filename
      (.results // [])[] |= (
        (.locations // [])[] |= (
          if .physicalLocation.artifactLocation.uri == "/"
             or .physicalLocation.artifactLocation.uri == "" then
            .physicalLocation.artifactLocation.uri = $sbom_uri
          else . end
        )
        # Clean message.text: remove trailing " at: " (with nothing after it)
        | if .message.text | endswith(" at: ") then .message.text |= .[:-5] else . end
      )
    )
  ' "$OUTPUT" > "${OUTPUT}.tmp"; then
    mv "${OUTPUT}.tmp" "$OUTPUT"
    echo "==> SARIF post-processed (fixed locations and messages)" >&2
  else
    echo "==> WARNING: SARIF post-processing failed, using raw grype output" >&2
    rm -f "${OUTPUT}.tmp"
  fi
fi

echo "==> ${FORMAT} written to ${OUTPUT}" >&2
